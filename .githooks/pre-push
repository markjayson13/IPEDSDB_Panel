python3 "$ROOT/Scripts/QA_QC/19_docs_style_guard.py" --repo-root "$ROOT"
python3 "$ROOT/Scripts/QA_QC/05_repo_size_guard.py" --repo-root "$ROOT" --max-file-size-mb 5 --top-n 25
